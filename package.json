    "react-dom": "^18.3.0",
    "storybook": "^8.6.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.2.0",
    "vitest": "^2.1.0",
    "vitest-axe": "^0.1.0"
