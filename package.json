    "@tremor/react": "^3.18.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.451.0",
